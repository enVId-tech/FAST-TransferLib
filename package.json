{
  "name": "fast-transferlib",
  "version": "25.10.02-release.6",
  "description": "A cross-platform transfer library for FAST File Explorer with automatic Rsync setup",
  "homepage": "https://github.com/enVId-tech/FAST-TransferLib#readme",
  "bugs": {
    "url": "https://github.com/enVId-tech/FAST-TransferLib/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enVId-tech/FAST-TransferLib.git"
  },
  "license": "GPL-3.0-only",
  "author": {
    "name": "Erick Tran",
    "url": "https://github.com/enVId-tech",
    "email": "erick.tran@etran.dev"
  },
  "type": "module",
  "main": "./dist/cjs/main.js",
  "module": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "require": "./dist/cjs/main.js",
      "default": "./dist/main.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "dist/cjs/package.json",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "fast-transfer": "dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node ./scripts/write-cjs-package.mjs",
    "dev": "tsc --watch",
    "prepack": "npm run build",
    "cli": "node dist/cli.js",
    "example": "npm run build && node example.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "ncu": "ncu -u && npm install"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "inquirer": "^13.3.0",
    "npm-check-updates": "^19.6.3"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "keywords": [
    "rsync",
    "file-transfer",
    "cross-platform",
    "cli",
    "typescript"
  ]
}
